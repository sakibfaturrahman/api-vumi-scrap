{
  "openapi": "3.0.0",
  "info": {
    "title": "VUMI - Komiku Rest API",
    "version": "1.0.0",
    "description": "API Backend untuk Aplikasi Comic Reader Vumi. Dikembangkan oleh Kibbz Skibidi.",
    "contact": {
      "name": "Kibbz Skibidi",
      "url": "https://sakibdev.my.id"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3001",
      "description": "Development Server"
    }
  ],
  "tags": [
    { "name": "Main", "description": "Endpoint utama untuk landing page" },
    {
      "name": "Manga Details",
      "description": "Informasi detail dan pembacaan chapter"
    },
    { "name": "Exploration", "description": "Pencarian, Genre, dan Pustaka" },
    {
      "name": "Popular",
      "description": "Komik sedang tren berdasarkan kategori"
    }
  ],
  "paths": {
    "/api/vumi/terbaru": {
      "get": {
        "tags": ["Main"],
        "summary": "Daftar komik terbaru",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/rekomendasi": {
      "get": {
        "tags": ["Main"],
        "summary": "Daftar rekomendasi pilihan",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/search": {
      "get": {
        "tags": ["Main"],
        "summary": "Pencarian komik",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "example": "solo leveling"
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/detail-komik/{slug}": {
      "get": {
        "tags": ["Manga Details"],
        "summary": "Detail informasi komik",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "bocchi-the-rock"
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/baca-chapter/{slug}/{chapter}": {
      "get": {
        "tags": ["Manga Details"],
        "summary": "Konten gambar per chapter",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "chapter",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "01"
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/genre-all": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Semua daftar genre",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/genre/{slug}": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Komik berdasarkan genre (Halaman 1)",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "action"
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/genre/{slug}/{page}": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Komik berdasarkan genre (Pagination)",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/genre-rekomendasi": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Genre yang direkomendasikan",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/berwarna": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Daftar komik berwarna (Halaman 1)",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/berwarna/page/{page}": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Daftar komik berwarna (Pagination)",
        "parameters": [
          {
            "name": "page",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/komik-populer/all": {
      "get": {
        "tags": ["Popular"],
        "summary": "Semua komik terpopuler",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/komik-populer/manga": {
      "get": {
        "tags": ["Popular"],
        "summary": "Manga terpopuler",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/komik-populer/manhwa": {
      "get": {
        "tags": ["Popular"],
        "summary": "Manhwa terpopuler",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/komik-populer/manhua": {
      "get": {
        "tags": ["Popular"],
        "summary": "Manhua terpopuler",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/pustaka": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Daftar pustaka komik (Halaman 1)",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/pustaka/page/{page}": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Daftar pustaka komik (Pagination)",
        "parameters": [
          {
            "name": "page",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}
