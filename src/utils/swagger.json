{
  "openapi": "3.0.0",
  "info": {
    "title": "VUMI - Komiku Rest API",
    "version": "1.0.0",
    "description": "API Backend yang dioptimasi untuk Aplikasi Comic Reader Vumi. Dikembangkan dengan Node.js dan Express oleh Sakib Faturrahman.",
    "contact": {
      "name": "Sakib Faturrahman",
      "url": "https://sakibdev.my.id",
      "email": "sakib@example.com"
    }
  },
  "servers": [
    {
      "url": "https://api-vumi-scrap.vercel.app",
      "description": "Production Server (Vercel)"
    },
    {
      "url": "http://localhost:3001",
      "description": "Local Development Server"
    }
  ],
  "tags": [
    {
      "name": "Main",
      "description": "Endpoint utama untuk konten landing page dan pencarian"
    },
    {
      "name": "Comic Details",
      "description": "Informasi mendalam mengenai komik (Manga, Manhwa, Manhua) dan konten pembacaan chapter"
    },
    {
      "name": "Exploration",
      "description": "Fitur penelusuran melalui Genre, Pustaka, dan filter Komik Berwarna"
    },
    {
      "name": "Popular",
      "description": "Daftar komik yang sedang tren berdasarkan kategori spesifik"
    }
  ],
  "paths": {
    "/api/vumi/terbaru": {
      "get": {
        "tags": ["Main"],
        "summary": "Daftar komik terbaru",
        "description": "Mengambil daftar komik yang baru saja diperbarui di server Komiku.",
        "responses": {
          "200": {
            "description": "Berhasil mendapatkan daftar komik terbaru"
          }
        }
      }
    },
    "/api/vumi/rekomendasi": {
      "get": {
        "tags": ["Main"],
        "summary": "Daftar rekomendasi pilihan",
        "description": "Mengambil daftar komik yang direkomendasikan secara editor.",
        "responses": {
          "200": {
            "description": "Berhasil mendapatkan rekomendasi"
          }
        }
      }
    },
    "/api/vumi/search": {
      "get": {
        "tags": ["Main"],
        "summary": "Pencarian komik",
        "description": "Mencari komik berdasarkan kata kunci judul.",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "solo leveling",
            "description": "Kata kunci pencarian"
          }
        ],
        "responses": {
          "200": {
            "description": "Hasil pencarian ditemukan"
          }
        }
      }
    },
    "/api/vumi/detail-komik/{slug}": {
      "get": {
        "tags": ["Comic Details"],
        "summary": "Detail informasi komik",
        "description": "Mengambil metadata lengkap, sinopsis, dan daftar chapter. Secara default mengakses kategori manga/manhwa sesuai ketersediaan di server.",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "kimetsu-no-yaiba-indonesia",
            "description": "Identifier unik komik (slug)"
          }
        ],
        "responses": {
          "200": {
            "description": "Detail komik berhasil dimuat"
          },
          "500": {
            "description": "Server Error (Cek ketersediaan URL scraping)"
          }
        }
      }
    },
    "/api/vumi/baca-chapter/{slug}/{chapter}": {
      "get": {
        "tags": ["Comic Details"],
        "summary": "Konten gambar per chapter",
        "description": "Mengambil seluruh gambar dari chapter komik yang dipilih.",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Slug komik"
          },
          {
            "name": "chapter",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "01",
            "description": "Nomor atau identitas chapter"
          }
        ],
        "responses": {
          "200": {
            "description": "Gambar chapter berhasil dimuat"
          }
        }
      }
    },
    "/api/vumi/genre-all": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Semua daftar genre",
        "responses": {
          "200": {
            "description": "Daftar genre tersedia"
          }
        }
      }
    },
    "/api/vumi/genre/{slug}": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Komik berdasarkan genre (Halaman 1)",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "action"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vumi/genre/{slug}/{page}": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Komik berdasarkan genre (Pagination)",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "example": 2
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vumi/genre-rekomendasi": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Genre yang direkomendasikan",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vumi/berwarna": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Daftar komik berwarna (Halaman 1)",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vumi/berwarna/page/{page}": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Daftar komik berwarna (Pagination)",
        "parameters": [
          {
            "name": "page",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "example": 2
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vumi/komik-populer/all": {
      "get": {
        "tags": ["Popular"],
        "summary": "Semua komik terpopuler",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vumi/komik-populer/manga": {
      "get": {
        "tags": ["Popular"],
        "summary": "Manga terpopuler",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vumi/komik-populer/manhwa": {
      "get": {
        "tags": ["Popular"],
        "summary": "Manhwa terpopuler",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vumi/komik-populer/manhua": {
      "get": {
        "tags": ["Popular"],
        "summary": "Manhua terpopuler",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vumi/pustaka": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Daftar pustaka komik (Halaman 1)",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/vumi/pustaka/page/{page}": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Daftar pustaka komik (Pagination)",
        "parameters": [
          {
            "name": "page",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "example": 2
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  }
}
