{
  "openapi": "3.0.0",
  "info": {
    "title": "VUMI - Komiku Rest API",
    "version": "1.0.0",
    "description": "API Backend yang dioptimasi untuk Aplikasi Comic Reader Vumi. Dikembangkan dengan Node.js dan Express oleh Kibbz Skibidi.",
    "contact": {
      "name": "Kibbz Skibidi",
      "url": "https://sakibdev.my.id"
    }
  },
  "servers": [
    {
      "url": "https://api-vumi-scrap.vercel.app",
      "description": "Production Server (Vercel)"
    },
    {
      "url": "http://localhost:3001",
      "description": "Local Development Server"
    }
  ],
  "tags": [
    {
      "name": "Main",
      "description": "Endpoint utama untuk landing page dan pencarian"
    },
    {
      "name": "Comic Details",
      "description": "Informasi detail komik dan konten gambar chapter"
    },
    {
      "name": "Exploration",
      "description": "Penelusuran melalui Genre, Pustaka, dan Filter Berwarna"
    },
    {
      "name": "Popular",
      "description": "Trending komik berdasarkan kategori"
    }
  ],
  "paths": {
    "/api/vumi/terbaru": {
      "get": {
        "tags": ["Main"],
        "summary": "Daftar komik terbaru",
        "responses": {
          "200": { "description": "Berhasil mendapatkan daftar komik terbaru" }
        }
      }
    },
    "/api/vumi/rekomendasi": {
      "get": {
        "tags": ["Main"],
        "summary": "Daftar rekomendasi pilihan",
        "responses": {
          "200": { "description": "Berhasil mendapatkan rekomendasi" }
        }
      }
    },
    "/api/vumi/search": {
      "get": {
        "tags": ["Main"],
        "summary": "Pencarian komik",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "example": "solo leveling"
          }
        ],
        "responses": {
          "200": { "description": "Hasil pencarian ditemukan" }
        }
      }
    },
    "/api/vumi/detail-komik/{slug}": {
      "get": {
        "tags": ["Comic Details"],
        "summary": "Detail informasi komik",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "kimetsu-no-yaiba-indonesia"
          }
        ],
        "responses": {
          "200": { "description": "OK" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/api/vumi/baca-chapter/{slug}/{chapter}": {
      "get": {
        "tags": ["Comic Details"],
        "summary": "Konten gambar per chapter",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "lookism"
          },
          {
            "name": "chapter",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "1"
          }
        ],
        "responses": {
          "200": { "description": "Gambar chapter berhasil dimuat" },
          "404": { "description": "Chapter tidak ditemukan" }
        }
      }
    },
    "/api/vumi/genre-all": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Semua daftar genre",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/genre/{slug}": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Komik berdasarkan genre (Halaman 1)",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "action"
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/genre/{slug}/{page}": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Komik berdasarkan genre (Pagination)",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "example": 2
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/berwarna": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Daftar komik berwarna (Halaman 1)",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/berwarna/page/{page}": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Daftar komik berwarna (Pagination)",
        "parameters": [
          {
            "name": "page",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/komik-populer/all": {
      "get": {
        "tags": ["Popular"],
        "summary": "Semua komik terpopuler",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/komik-populer/manga": {
      "get": {
        "tags": ["Popular"],
        "summary": "Manga terpopuler",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/komik-populer/manhwa": {
      "get": {
        "tags": ["Popular"],
        "summary": "Manhwa terpopuler",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/komik-populer/manhua": {
      "get": {
        "tags": ["Popular"],
        "summary": "Manhua terpopuler",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/pustaka": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Daftar pustaka komik (Halaman 1)",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/vumi/pustaka/page/{page}": {
      "get": {
        "tags": ["Exploration"],
        "summary": "Daftar pustaka komik (Pagination)",
        "parameters": [
          {
            "name": "page",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}
